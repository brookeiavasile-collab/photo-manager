{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PhotoManager",
  "version": "1.0.0",
  "identifier": "com.photomanager.app",
  "build": {
    "beforeDevCommand": "npm --prefix frontend run dev",
    "devUrl": "http://localhost:3002",
    "beforeBuildCommand": "npm --prefix frontend run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Photo Manager",
        "width": 1440,
        "height": 960,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$CWD/**",
          "$RESOURCE/**",
          "$APPDATA/**",
          "$APPLOCALDATA/**",
          "$APPLOG/**",
          "$APPCONFIG/**",
          "C:/**",
          "D:/**",
          "E:/**",
          "F:/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
